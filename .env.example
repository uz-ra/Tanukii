WHISPER_MODEL=small
WHISPER_COMPUTE_TYPE=int8

# Summary provider: auto | gemini | openai | local
SUMMARY_PROVIDER=auto

# Optional OpenAI summary settings
OPENAI_API_KEY=
OPENAI_SUMMARY_MODEL=gpt-4.1-mini

# Optional Gemini summary settings
GEMINI_API_KEY=
GEMINI_SUMMARY_MODEL=gemini-2.0-flash

# For LAN access, set strict origins in production-like usage
# Example: CORS_ORIGINS=http://192.168.0.20:8000
CORS_ORIGINS=*
